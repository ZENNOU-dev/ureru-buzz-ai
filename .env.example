# Claude API
ANTHROPIC_API_KEY=

# Notion
NOTION_API_KEY=

# ureru-buzz-ai Supabase (READ/WRITE)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ad Orchestration Supabase (READ ONLY)
AD_ORCH_SUPABASE_URL=
AD_ORCH_SUPABASE_KEY=

# video-material-selector Supabase (READ ONLY)
VMS_SUPABASE_URL=
VMS_SUPABASE_KEY=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Meta Ads
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# TikTok Ads
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Kling AI
KLING_API_KEY=
KLING_API_URL=https://api.klingai.com/v1

# Redis
REDIS_URL=redis://localhost:6379

# TTS
TTS_API_KEY=
TTS_PROVIDER=elevenlabs

# Remotion
REMOTION_SERVE_URL=

# Web dev: Next の Route Handler がサーバー側で叩く API ベース URL（/health を付与）
# 未設定かつ NODE_ENV=development のときは http://127.0.0.1:8787
# API 起動: pnpm --filter @ureru-buzz-ai/api dev
BACKEND_INTERNAL_URL=http://127.0.0.1:8787
# API のポート（api パッケージの server.ts。PORT でも可）
# API_PORT=8787
# ヘルスチェック無効化（開発用）
# SKIP_BACKEND_HEALTH_CHECK=1
